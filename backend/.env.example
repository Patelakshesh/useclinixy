PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/doctor-saas
JWT_SECRET=super_secret_jwt_key_123
JWT_EXPIRES_IN=1d
FRONTEND_URL=http://localhost:3000

# Razorpay Payment Gateway (Test or Live Keys)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Meta WhatsApp Cloud API (Test or Live)
WHATSAPP_API_TOKEN=your_meta_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_test_phone_number_id

# Email (SMTP) - Use Gmail App Password or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password_here
